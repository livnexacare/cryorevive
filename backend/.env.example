# CryoRevive Backend — copy to .env and fill in values

# Supabase PostgreSQL connection string
# Found in: Supabase > Project > Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Email config
SENDER_EMAIL=noreply@cryorevive.com
SUPPORT_EMAIL=info@cryorevive.com
# Set this to your own email during development so all emails go to you
RESEND_FORCE_RECIPIENT=

# Admin seed credentials (set before first deploy)
ADMIN_EMAIL=admin@cryorevive.com
ADMIN_PASSWORD=change-me-before-deploy

# Frontend URL for password reset links
FRONTEND_URL=https://cryo-revive-main.vercel.app

# Cloudflare R2 Storage
# Found in: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=cryorevive
# Public URL of your R2 bucket (enable in R2 bucket settings)
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
