# CryoRevive Backend — copy to .env and fill in values

# ── Database ───────────────────────────────────────────────────────────────────
# Supabase > Project > Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
# Set after cryorevive.in is verified in Resend dashboard
BOOKING_EMAIL_FROM=CryoRevive Bookings <booking@cryorevive.in>
SUPPORT_EMAIL_FROM=CryoRevive Support <support@cryorevive.in>
ADMIN_EMAIL=admin@livnexacare.com
SUPPORT_DEST_EMAIL=support@cryorevive.in

# ── Admin ──────────────────────────────────────────────────────────────────────
# API key for blog CRUD and file uploads (choose a strong random string)
ADMIN_API_KEY=

# ── Frontend / CORS ────────────────────────────────────────────────────────────
FRONTEND_URL=https://cryo-revive-main.vercel.app
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=https://cryo-revive-main.vercel.app

# ── Cloudflare R2 Storage ──────────────────────────────────────────────────────
# Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_KEY=your-r2-secret-access-key
R2_BUCKET=cryorevive-media
# Enable public access on the R2 bucket, then paste the URL here
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Razorpay (Payments) ────────────────────────────────────────────────────────
# https://dashboard.razorpay.com > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
# Webhook secret: Razorpay Dashboard > Webhooks > your endpoint > secret
RAZORPAY_WEBHOOK_SECRET=
