# CryoRevive Frontend — copy to .env.local and fill in values

# Backend API URL (set after deploying backend on Render)
NEXT_PUBLIC_API_URL=https://cryorevive.onrender.com

# Supabase (used for blog content reads)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# WhatsApp — admin number with country code (no +, no spaces)
# e.g. India: 918595850920  (91 = country code, then 10-digit number)
NEXT_PUBLIC_ADMIN_WHATSAPP=918595850920
NEXT_PUBLIC_WHATSAPP_NUMBER=918595850920

# Admin panel login (server-side only — never expose in NEXT_PUBLIC_)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# Admin API key — must match ADMIN_API_KEY set in Render backend env vars
# Used by the admin dashboard to call protected backend routes
NEXT_PUBLIC_ADMIN_API_KEY=your-admin-api-key-here

# PWA Push Notifications (VAPID)
# Generate your own keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
# Backend only — never expose in frontend
VAPID_PRIVATE_KEY=your-vapid-private-key-here
# Used as VAPID contact email for push services
ADMIN_EMAIL=admin@livnexacare.com

# Resend — set after cryorevive.in is verified in Resend dashboard
RESEND_API_KEY=re_your_resend_api_key
BOOKING_EMAIL_FROM=CryoRevive Bookings <booking@cryorevive.in>
SUPPORT_EMAIL_FROM=CryoRevive Support <support@cryorevive.in>
SUPPORT_DEST_EMAIL=support@cryorevive.in
