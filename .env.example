# CryoRevive Frontend — copy to .env.local and fill in values

# Backend API URL (set after deploying backend on Render)
NEXT_PUBLIC_API_URL=https://cryorevive-backend.onrender.com

# Razorpay (frontend payment initiation via Next.js API routes)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Admin panel login (server-side only — never expose in NEXT_PUBLIC_)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here
